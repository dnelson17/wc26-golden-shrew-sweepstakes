---
import '../styles/global.css';
import { leagueList } from '../leagues';

const leagues = leagueList();
const slugs = leagues.map((l) => l.slug);
// Returning visitors skip the picker and go straight to their last league.
// `?pick=1` (the header "Switch" link) forces the picker to show.
const redirect = `(function(){var p=new URLSearchParams(location.search);if(p.has('pick'))return;var last=localStorage.getItem('league:last');var valid=${JSON.stringify(
  slugs,
)};if(last&&valid.indexOf(last)>-1)location.replace('/'+last);})();`;
---

<!doctype html>
<html lang="en" class="bg-slate-100 dark:bg-slate-950">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f59e0b" />
    <title>World Cup Sweepstakes</title>
    <meta name="description" content="Live 2026 World Cup sweepstake prize trackers." />
    <script is:inline set:html={redirect} />
  </head>
  <body
    class="flex min-h-dvh flex-col items-center justify-center px-4 py-10 text-slate-900 dark:text-slate-100"
  >
    <main class="w-full max-w-md">
      <div class="mb-8 text-center">
        <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">
          <span class="bg-gradient-to-r from-amber-500 to-orange-600 bg-clip-text text-transparent"
            >World Cup Sweepstakes</span
          >
        </h1>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Pick your league</p>
      </div>

      <div class="space-y-3">
        {
          leagues.map((l) => (
            <a
              href={`/${l.slug}`}
              class="flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-amber-400 hover:shadow-md dark:border-slate-700 dark:bg-slate-800"
            >
              <span class="text-3xl leading-none">
                {l.headerEmojis[0]}
                {l.headerEmojis[1]}
              </span>
              <span class="min-w-0 flex-1">
                <span class="block truncate font-bold">{l.name}</span>
                <span class="block truncate text-xs text-slate-500 dark:text-slate-400">
                  {l.tagline}
                </span>
              </span>
              <span class="text-slate-300 dark:text-slate-600">→</span>
            </a>
          ))
        }
      </div>
    </main>
  </body>
</html>
