{
  "name": "wc26-golden-shrew-sweepstakes",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fetch": "node scripts/fetch.mjs",
    "simulate": "node scripts/simulate.mjs",
    "snapshot": "node scripts/use-snapshot.mjs",
    "test:compute": "node scripts/test-compute.mjs && node scripts/test-compute-nelson.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,astro,mjs,js}": [
